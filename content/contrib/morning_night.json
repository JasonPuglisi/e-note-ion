{
  "templates": {
    "good_morning": {
      "schedule": {
        "cron": "0 7 * * *",
        "hold": 300,
        "timeout": 3600
      },
      "priority": 3,
      "templates": [
        {
          "format": [
            "[Y] GOOD MORNING",
            "RISE AND SHINE"
          ]
        },
        {
          "format": [
            "[Y] GOOD MORNING",
            "LET'S DO THIS"
          ]
        },
        {
          "format": [
            "[Y] GOOD MORNING",
            "HAPPY TO",
            "SEE YOU"
          ]
        },
        {
          "format": [
            "[Y] GOOD MORNING",
            "LOOK ALIVE"
          ]
        },
        {
          "format": [
            "[Y] GOOD MORNING",
            "HERE COMES",
            "THE SUN"
          ]
        },
        {
          "format": [
            "[Y] GOOD MORNING",
            "EYES OPEN"
          ]
        },
        {
          "format": [
            "[Y] GOOD MORNING",
            "OFF WE GO"
          ]
        },
        {
          "format": [
            "[Y] GOOD MORNING",
            "UP AND AT 'EM"
          ]
        },
        {
          "format": [
            "[Y] GOOD MORNING",
            "HERE WE GO"
          ]
        },
        {
          "format": [
            "[Y] GOOD MORNING",
            "STEPPING IN"
          ]
        }
      ]
    },
    "good_morning_september": {
      "schedule": {
        "cron": "0 7 21 9 *",
        "hold": 300,
        "timeout": 3600
      },
      "priority": 4,
      "templates": [
        {
          "format": [
            "DO YOU REMEMBER",
            "THE 21ST NIGHT",
            "OF SEPTEMBER"
          ]
        }
      ]
    },
    "good_night": {
      "schedule": {
        "cron": "0 21 * * *",
        "hold": 300,
        "timeout": 3600
      },
      "priority": 3,
      "integration": "moon",
      "templates": [
        {
          "format": [
            "{moon_row1} GOOD",
            "{moon_row2} NIGHT",
            "{moon_row3}"
          ]
        }
      ]
    }
  }
}
