{
  "templates": {
    "good_morning": {
      "schedule": {
        "cron": "0 7 * * *",
        "hold": 300,
        "timeout": 3600
      },
      "priority": 3,
      "integration": "morning",
      "templates": [
        {
          "format": [
            "{morning_r1} GOOD",
            "{morning_r2} MORNING",
            "{morning_r3}"
          ]
        }
      ]
    },
    "good_morning_september": {
      "schedule": {
        "cron": "0 7 21 9 *",
        "hold": 300,
        "timeout": 3600
      },
      "priority": 4,
      "templates": [
        {
          "format": [
            "DO YOU REMEMBER",
            "THE 21ST NIGHT",
            "OF SEPTEMBER"
          ]
        }
      ]
    },
    "good_night": {
      "schedule": {
        "cron": "0 21 * * *",
        "hold": 300,
        "timeout": 3600
      },
      "priority": 3,
      "integration": "moon",
      "templates": [
        {
          "format": [
            "{moon_row1} GOOD",
            "{moon_row2} NIGHT",
            "{moon_row3}"
          ]
        }
      ]
    }
  }
}
